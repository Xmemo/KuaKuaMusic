{
  "manifest_version": 3,
  "name": "夸夸音乐",
  "version": "2.0",
  "description": "输入歌名，夸夸音乐会立刻生成 3 种风格的高质量夸歌文案（走心 / 上头 / 懂行）。",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "*://music.163.com/*",
    "*://y.qq.com/*",
    "*://music.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://music.163.com/*",
        "*://y.qq.com/*",
        "*://music.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
